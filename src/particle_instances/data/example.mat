material {
    name : "White",
    blending : opaque,
    shadingModel : lit,
    instanced : true,
    culling : none,
    requires :
    [
        uv0,
        color
    ]
}

vertex
{
    void materialVertex(inout MaterialVertexInputs material)
    {
        // Calculate vertex position
        highp float3 position = getPosition().xyz;
        position.x += cos(1.0 * float(getInstanceIndex() + 1)) * 20.0;
        position.y += sin(0.9 * float(getInstanceIndex() + 1)) * 20.0;

        material.worldPosition = mulMat4x4Float3(getWorldFromModelMatrix(), position);

        // Calculate color over velocity on the vertexs
        float alpha = (sin(getUserTime().x * ((2.0 * 0.25)) + 1.0) / 2.0);
        vec3 color = mix(vec3(0.24, 0.85, 0.37), vec3(1.0, 0.98, 0.0), alpha);
        material.color = vec4(color, alpha);
    }
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        material.baseColor = vec4(1.0, 0.0, 0.0, 1.0);
    }
}
