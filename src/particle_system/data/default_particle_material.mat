material {
    parameters : 
    [
        {
            type : sampler2d,
            name : BaseTexture,
        },
        {
            type : float3,
            name : Velocity,
        },
        {
            type : float,
            name : Life,
        }
    ],
    requires : 
    [
        uv0,
        color
    ],
    name : "Particle Material",
    blending : transparent,
    shadingModel : unlit,
}

vertex
{
    float animationTime(float endValue)
    {
        float currentTime = mod(getUserTime().x, endValue); // Current time in seconds
        float t = currentTime / endValue; // Interpolation factor between 0.0 and 1.0
        return mix(0.0, endValue, t);
    }

    void materialVertex(inout MaterialVertexInputs material)
    {
        // Calculate vertex position
        float3 position = getPosition().xyz;
        position.x += cos(animationTime(materialParams.Life) * materialParams.Velocity.x) * 15.0;
        position.y += sin(animationTime(materialParams.Life) * materialParams.Velocity.y) * 15.0;
        material.worldPosition = mulMat4x4Float3(getWorldFromModelMatrix(), position);

        // Calculate color over velocity on the vertexs
        float alpha = (sin(getUserTime().x * ((materialParams.Velocity.x * 0.25)) + 1.0) / 2.0);
        vec3 color = mix(vec3(0.24, 0.85, 0.37), vec3(1.0, 0.98, 0.0), alpha);
        material.color = vec4(color, alpha);
    }
}

fragment 
{
    void material(inout MaterialInputs material)
    {
        prepareMaterial(material);

        vec4 srgb_color = texture(materialParams_BaseTexture, getUV0());

        // Get previous color calculated in the vertex shader
        float alpha = srgb_color.a * getColor().a;
        material.baseColor = vec4(getColor().rgb * alpha, alpha);
    }
}
